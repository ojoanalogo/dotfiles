#!/usr/bin/env bash
echo "laptop" > $HOME/.current-layout
xrandr --output DP-0 --off --output DP-1 --off --output DP-2 --off --output DP-3 --off --output DP-4 --off --output DP-5 --off --output eDP-1-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal --output VGA-1-1 --off --output DP-1-1 --off --output HDMI-1-1 --off &&\
$HOME/Code/dotfiles/scripts/layouts/postswitch

if [ $? -eq 1 ]; then
    # notify about error on layout switch
    notify-send -u critical "Screen" "Error on layout switch, check output"
fi