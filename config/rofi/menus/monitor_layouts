#!/usr/bin/env bash

dir="$HOME/.config/rofi/themes/everblush"

rofi_command="rofi -theme $dir/monitor_menu.rasi"

# Options
laptop="ï„‰"
single_monitor="ï¡¸"
double_monitor="ï¡¹"
monitor_and_laptop="ï„‰   ï¡¸"
all_monitors_and_laptop="ï„‰   ï¡¹"

# Variable passed to rofi
options="$laptop\n$single_monitor\n$double_monitor\n$monitor_and_laptop\n$all_monitors_and_laptop"

chosen="$(echo -e "$options" | $rofi_command -p "Monitor layout" -dmenu -selected-row 0)"
case $chosen in
$laptop)
    $HOME/Code/dotfiles/scripts/layouts/laptop
    ;;
$single_monitor)
    $HOME/Code/dotfiles/scripts/layouts/single_monitor
    ;;
$double_monitor)
    $HOME/Code/dotfiles/scripts/layouts/double_monitor
    ;;
$monitor_and_laptop)
    $HOME/Code/dotfiles/scripts/layouts/monitor_and_laptop
    ;;
$all_monitors_and_laptop)
    $HOME/Code/dotfiles/scripts/layouts/all_monitors_and_laptop
    ;;
esac
